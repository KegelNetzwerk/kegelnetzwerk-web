// Prisma schema for KegelNetzwerk
// Multi-tenant: all clubs share one database, separated by clubId

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  MEMBER
  ADMIN
}

enum Unit {
  POINTS
  EURO
}

enum CommentType {
  NEWS
  VOTE
  EVENT
}

enum FinanceFrequency {
  NONE
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum FinanceTxType {
  PENALTY        // auto-calculated from euro-unit scoring results at payoff time
  CLUB_FEE       // regular club fee charged at payoff time
  PAYMENT_IN     // member paid into club (increases balance / credit)
  PAYMENT_OUT    // manual debit / charge to member (decreases balance)
  CLUB_PURCHASE  // club-level expense, no member (logged only)
  COLLECTIVE     // charge for a collective event/trip
  REGULAR_INCOME // auto payment-in included at payoff time
  RESET          // balance reset transaction
  MANUAL         // free-form manual adjustment
}

// ─── Club ────────────────────────────────────────────────────────────────────

model Club {
  id             Int      @id @default(autoincrement())
  name           String   @unique // used as URL slug
  regCode        String   // hashed registration code
  regDate        DateTime @default(now())

  // Appearance
  pic            String   @default("none")   // logo image path
  header         String   @default("none")   // banner image path
  aboutUs        String   @default("")       // rich text "Über uns"
  farbe1         String   @default("005982") // primary color hex
  farbe2         String   @default("3089AC") // secondary color hex
  farbe3         String   @default("A91A1A") // accent color hex
  mono           Boolean  @default(false)
  bg1            Int      @default(0)        // background preset 0-2
  bg2            Int      @default(0)        // inner background preset 0-3
  bgColor        String   @default("FFFFFF") // custom background color hex

  // Configurable settings
  cancelDaysBeforeEvent Int    @default(5)  // days before event after which cancellation is no longer possible
  defaultScoringFilter  String @default("") // query string for default scoring page filter

  // Banking info (displayed on cash overview)
  accountHolder  String   @default("")
  accountNumber  String   @default("")
  bankCode       String   @default("")
  iban           String   @default("")
  bic            String   @default("")
  paypal         String   @default("")

  createdAt      DateTime @default(now())

  // Relations
  members                Member[]
  guests                 Guest[]
  clubComments           ClubComment[]
  secretSantaAssignments SecretSantaAssignment[]
  news                 News[]
  votes                Vote[]
  events               Event[]
  eventRecurrenceRules EventRecurrenceRule[]
  gamesOrPenalties     GameOrPenalty[]
  parts            Part[]
  results          Result[]
  financeSettings      ClubFinanceSettings?
  payoffEvents         PayoffEvent[]
  financeTransactions  FinanceTransaction[]
  collectiveCharges    CollectiveCharge[]
}

// ─── Member ───────────────────────────────────────────────────────────────────

model Member {
  id                   Int      @id @default(autoincrement())
  clubId               Int
  club                 Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  nickname             String
  email                String   @default("")
  firstName            String   @default("")
  lastName             String   @default("")
  birthday             DateTime?
  passwordHash         String
  role                 Role     @default(MEMBER)
  pic                  String   @default("none") // avatar path
  phone                String   @default("")

  // Secret Santa self-relation (current assignment)
  secretSantaPartnerId Int?
  secretSantaPartner   Member?  @relation("SecretSanta", fields: [secretSantaPartnerId], references: [id])
  secretSantaOf        Member[] @relation("SecretSanta")
  secretSantaGiven     SecretSantaAssignment[] @relation("SecretSantaGiver")
  secretSantaReceived  SecretSantaAssignment[] @relation("SecretSantaReceiver")

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  sessions             Session[]
  passwordResetTokens  PasswordResetToken[]
  authoredNews             News[]               @relation("NewsAuthor")
  authoredVotes            Vote[]               @relation("VoteAuthor")
  authoredEvents           Event[]              @relation("EventAuthor")
  authoredRecurrenceRules  EventRecurrenceRule[] @relation("RecurrenceRuleAuthor")
  votings              Voting[]
  eventCancellations   EventCancellation[]
  comments             Comment[]
  results              Result[]
  profileComments          MemberComment[] @relation("ProfileComments")
  authoredMemberComments   MemberComment[] @relation("AuthoredMemberComments")
  authoredClubComments     ClubComment[]   @relation("AuthoredClubComments")
  pushToken                PushToken?
  financeTransactions      FinanceTransaction[]
  collectiveAssignments    CollectiveChargeAssignment[]
  regularMemberPayments    RegularMemberPayment[]
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  memberId  Int
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  memberId  Int
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model RegistrationCode {
  id        Int      @id @default(autoincrement())
  code      String   @unique // hashed
  createdAt DateTime @default(now())
}

model PushToken {
  id        Int      @id @default(autoincrement())
  memberId  Int      @unique
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── News ─────────────────────────────────────────────────────────────────────

model News {
  id             Int      @id @default(autoincrement())
  clubId         Int
  club           Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  authorId       Int
  author         Member   @relation("NewsAuthor", fields: [authorId], references: [id])
  editorIds      String   @default("") // comma-separated member IDs
  title          String
  content        String   // rich text (HTML)
  internal       Boolean  @default(false)
  emailNotified  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  comments       Comment[]
}

// ─── Votes / Polls ────────────────────────────────────────────────────────────

model Vote {
  id             Int      @id @default(autoincrement())
  clubId         Int
  club           Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  authorId       Int
  author         Member   @relation("VoteAuthor", fields: [authorId], references: [id])
  title          String
  description    String   @default("") // rich text
  maxVoices      Int      @default(1)  // -1 = unlimited
  anonymous      Boolean  @default(false)
  maybe          Boolean  @default(false)
  previewResults Boolean  @default(false)
  allowSwitch    Boolean  @default(false)
  closed         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  options        VoteOption[]
  votings        Voting[]
  comments       Comment[]
}

model VoteOption {
  id       Int    @id @default(autoincrement())
  voteId   Int
  vote     Vote   @relation(fields: [voteId], references: [id], onDelete: Cascade)
  text     String
  position Int    @default(0)

  votings  Voting[]
}

model Voting {
  id        Int        @id @default(autoincrement())
  voteId    Int
  vote      Vote       @relation(fields: [voteId], references: [id], onDelete: Cascade)
  optionId  Int
  option    VoteOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  memberId  Int
  member    Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  maybe     Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// ─── Events ───────────────────────────────────────────────────────────────────

model EventRecurrenceRule {
  id            Int      @id @default(autoincrement())
  clubId        Int
  club          Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  authorId      Int
  author        Member   @relation("RecurrenceRuleAuthor", fields: [authorId], references: [id])
  subject       String
  location      String   @default("")
  description   String   @default("") // rich text
  // "EVERY_N_WEEKS" | "MONTHLY" | "YEARLY"
  type          String
  intervalWeeks Int?     // only for EVERY_N_WEEKS
  startDate     DateTime
  createdAt     DateTime @default(now())

  events        Event[]
}

model Event {
  id                 Int                  @id @default(autoincrement())
  clubId             Int
  club               Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  authorId           Int
  author             Member               @relation("EventAuthor", fields: [authorId], references: [id])
  date               DateTime
  subject            String
  location           String               @default("")
  description        String               @default("") // rich text
  recurrenceRuleId   Int?
  recurrenceRule     EventRecurrenceRule? @relation(fields: [recurrenceRuleId], references: [id], onDelete: SetNull)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  cancellations EventCancellation[]
  comments      Comment[]
}

model EventCancellation {
  id        Int      @id @default(autoincrement())
  eventId   Int
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId  Int
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, memberId])
}

// ─── Comments ─────────────────────────────────────────────────────────────────

model Comment {
  id          Int         @id @default(autoincrement())
  authorId    Int
  author      Member      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content     String
  type        CommentType
  referenceId Int         // FK to News.id, Vote.id, or Event.id

  // Optional explicit FK relations for each type
  news        News?       @relation(fields: [newsId], references: [id], onDelete: Cascade)
  newsId      Int?
  vote        Vote?       @relation(fields: [voteId], references: [id], onDelete: Cascade)
  voteId      Int?
  event       Event?      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     Int?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ─── Secret Santa History ─────────────────────────────────────────────────────

model SecretSantaAssignment {
  id         Int      @id @default(autoincrement())
  clubId     Int
  club       Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  giverId    Int
  giver      Member   @relation("SecretSantaGiver", fields: [giverId], references: [id], onDelete: Cascade)
  receiverId Int
  receiver   Member   @relation("SecretSantaReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  year       Int

  createdAt  DateTime @default(now())

  @@unique([clubId, giverId, year])
}

// ─── Club Comments ────────────────────────────────────────────────────────────

model ClubComment {
  id             Int      @id @default(autoincrement())
  clubId         Int
  club           Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  authorMemberId Int?
  authorMember   Member?  @relation("AuthoredClubComments", fields: [authorMemberId], references: [id], onDelete: SetNull)
  guestName      String   @default("")
  content        String

  createdAt      DateTime @default(now())
}

// ─── Member Profile Comments ──────────────────────────────────────────────────

model MemberComment {
  id              Int      @id @default(autoincrement())
  profileMemberId Int
  profileMember   Member   @relation("ProfileComments", fields: [profileMemberId], references: [id], onDelete: Cascade)
  authorMemberId  Int?
  authorMember    Member?  @relation("AuthoredMemberComments", fields: [authorMemberId], references: [id], onDelete: SetNull)
  guestName       String   @default("")
  content         String

  createdAt       DateTime @default(now())
}

// ─── Guest ────────────────────────────────────────────────────────────────────

model Guest {
  id        Int      @id @default(autoincrement())
  clubId    Int
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  nickname  String
  firstName String   @default("")
  lastName  String   @default("")

  results   Result[]

  createdAt DateTime @default(now())

  @@unique([clubId, nickname])
}

// ─── Scoring ──────────────────────────────────────────────────────────────────

model GameOrPenalty {
  id      Int    @id @default(autoincrement())
  clubId  Int
  club    Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name    String

  parts   Part[]
  results Result[]

  createdAt DateTime @default(now())
}

model Part {
  id               Int           @id @default(autoincrement())
  clubId           Int
  club             Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  gameOrPenaltyId  Int
  gameOrPenalty    GameOrPenalty @relation(fields: [gameOrPenaltyId], references: [id], onDelete: Cascade)
  name             String
  unit             Unit          @default(POINTS)
  once             Boolean       @default(false) // fixed per session
  value            Float         @default(0)
  variable         Boolean       @default(false) // value entered at result-entry time
  factor           Float         @default(1.0)
  bonus            Float         @default(0.0)
  description      String        @default("") // rich text
  pic              String        @default("none")

  results          Result[]

  createdAt        DateTime      @default(now())
}

model Result {
  id              Int           @id @default(autoincrement())
  clientId        String?       @unique // UUID sent by the app; used for client-initiated deletion
  clubId          Int
  club            Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  memberId        Int?          // null for guest results
  member          Member?       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  guestId         Int?          // null for member results
  guest           Guest?        @relation(fields: [guestId], references: [id], onDelete: Cascade)
  partId          Int
  part            Part          @relation(fields: [partId], references: [id], onDelete: Cascade)
  gopId           Int
  gameOrPenalty   GameOrPenalty @relation(fields: [gopId], references: [id], onDelete: Cascade)
  value           Float
  date            DateTime
  sessionGroup    Int           // groups results that belong to the same game session

  createdAt       DateTime      @default(now())
}

// ─── Finance ──────────────────────────────────────────────────────────────────

model ClubFinanceSettings {
  id                   Int               @id @default(autoincrement())
  clubId               Int               @unique
  club                 Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  feeAmount            Float             @default(0)
  feeFrequency         FinanceFrequency  @default(NONE)
  autoPayoffEnabled    Boolean           @default(false)
  autoPayoffFrequency  FinanceFrequency  @default(MONTHLY)
  autoPayoffDayOfMonth Int               @default(1)
  lastPayoffAt         DateTime?

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

model PayoffEvent {
  id           Int      @id @default(autoincrement())
  clubId       Int
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  fromDate     DateTime?  // null = since beginning of time
  toDate       DateTime
  feeAmount    Float    @default(0)
  note         String   @default("")
  createdAt    DateTime @default(now())

  transactions FinanceTransaction[]
}

model FinanceTransaction {
  id            Int             @id @default(autoincrement())
  clubId        Int
  club          Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  memberId      Int?
  member        Member?         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type          FinanceTxType
  amount        Float           // positive = credit (member paid), negative = debit (member owes)
  note          String          @default("")
  payoffEventId Int?
  payoffEvent   PayoffEvent?    @relation(fields: [payoffEventId], references: [id], onDelete: SetNull)
  collectiveId  Int?
  collective    CollectiveCharge? @relation(fields: [collectiveId], references: [id], onDelete: SetNull)
  date          DateTime        @default(now())
  createdAt     DateTime        @default(now())
}

model CollectiveCharge {
  id            Int      @id @default(autoincrement())
  clubId        Int
  club          Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name          String
  defaultAmount Float
  note          String   @default("")
  closed        Boolean  @default(false)
  createdAt     DateTime @default(now())

  assignments   CollectiveChargeAssignment[]
  transactions  FinanceTransaction[]
}

model CollectiveChargeAssignment {
  id           Int              @id @default(autoincrement())
  collectiveId Int
  collective   CollectiveCharge @relation(fields: [collectiveId], references: [id], onDelete: Cascade)
  memberId     Int
  member       Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount       Float
  excluded     Boolean          @default(false)
  paidAt       DateTime?

  createdAt    DateTime         @default(now())

  @@unique([collectiveId, memberId])
}

model RegularMemberPayment {
  id        Int              @id @default(autoincrement())
  clubId    Int
  memberId  Int
  member    Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount    Float
  frequency FinanceFrequency
  note      String           @default("")
  active    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}
